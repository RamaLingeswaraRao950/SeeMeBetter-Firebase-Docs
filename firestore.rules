rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Handle -> uid mapping for public links like /{handle}/feedback.
    match /handles/{handle} {
      allow get, list: if true;
      allow create: if isSignedIn()
        && !exists(/databases/$(database)/documents/handles/$(handle))
        && request.resource.data.keys().hasOnly(["uid", "handle", "createdAt"])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.handle == handle;
      allow update, delete: if false;
    }

    // Public user profile/settings (simple mode): readable by anyone.
    // IMPORTANT: Only store public-safe fields in this document.
    match /users/{uid} {
      // "Simple mode": this document is publicly readable, but should only contain public-safe fields.
      // Public pages only need `get` (they already know uid via `handles/{handle}`), so disallow `list`.
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if isOwner(uid);

      match /questions/{questionId} {
        // Owner can read/manage all their questions. Public can only read active, non-deleted questions.
        allow get, list: if isOwner(uid) || (resource.data.active == true && resource.data.isDeleted == false);
        allow create, update, delete: if isOwner(uid);
      }

      match /responses/{responseId} {
        // Public can only create.
        allow create: if request.auth == null
          && request.resource.data.keys().hasOnly(["createdAt", "anonymousId", "source", "answers", "formHandle"])
          && request.resource.data.anonymousId is string
          && request.resource.data.anonymousId.size() >= 8
          && request.resource.data.source == "web"
          && request.resource.data.formHandle is string
          && request.resource.data.formHandle.size() >= 3
          // `serverTimestamp()` is evaluated to `request.time` in rules.
          && request.resource.data.createdAt == request.time
          && request.resource.data.answers is list
          && request.resource.data.answers.size() > 0
          && request.resource.data.answers.size() <= 200;

        // Prevent public read/delete.
        allow read, delete: if false;

        // Public can append "3 words" shortly after submit.
        allow update: if request.auth == null
          && resource.data.source == "web"
          && request.writeFields.size() == 1
          && request.writeFields.hasOnly(["answers"])
          // Allow a reasonable window for users to reach /thank-you and submit optional "3 words".
          && request.time < resource.data.createdAt + duration.value(24, "h")
          && resource.data.answers is list
          && resource.data.answers.size() <= 200;

        // Owner can read/manage.
        allow get, list, update, delete: if isOwner(uid);
      }
    }
  }
}
